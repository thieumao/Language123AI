generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   Json
  level     String?
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

